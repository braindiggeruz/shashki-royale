<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ShashkiRoyale" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/brand_gold</item>
        <item name="colorPrimaryDark">@color/brand_background_dark</item>
        <item name="colorAccent">@color/brand_red</item>
        <item name="android:windowBackground">@color/brand_background</item>
        <item name="android:statusBarColor">@color/brand_background_dark</item>
        <item name="android:navigationBarColor">@color/brand_background_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <style name="Theme.ShashkiRoyale.Splash" parent="Theme.ShashkiRoyale">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>
